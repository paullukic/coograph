# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.idea/
.vscode/
*.iml
**/__pycache__/

# Environment
.env
.env.local

# Override global gitignore — include project files in this repo
!.claude/
!CLAUDE.md
!.github/
!.github/code-graph/
!AGENTS.md
!.mcp.json
!openspec/
# Per-tool native config dirs at repo root
!.agents/
!.agents/**
!.opencode/
!.opencode/coograph-init.md
!.opencode/commands/
!.opencode/commands/**
# Per-tool template files (templates/ ships native config for each AI tool)
!templates/
!templates/**
# Project-level docs (screenshots, diagrams)
!docs/
!docs/**
# Codespaces dev container
!.devcontainer/
!.devcontainer/**

# Per-project bash audit log (written by .claude/hooks/log-bash.py)
.claude/session.log
.claude/sessions/
# Local Claude Code overrides — never synced, never committed
.claude/settings.local.json

# Local AI tool state (machine-specific)
.omc/

# Generated artifacts (local only)
.code-graph/
**/node_modules/

# Machine-specific project registry and sync log (each user has their own)
projects.json
.github/sync.log

# OpenSpec change archives (optional — uncomment to ignore)
# openspec/changes/archive/
